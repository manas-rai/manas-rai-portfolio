# Copy to .env for local development. Never commit real secrets.

IS_PRODUCTION=false

# Email delivery — set RESEND_API_KEY to use Resend, or SMTP_* to use SMTP.
# If neither is set, contact submissions fail gracefully with the direct-email
# fallback (they are not silently dropped).
# RESEND_API_KEY=
EMAIL_FROM=portfolio@manasrai.dev
